<?xml version="1.0" encoding="UTF-8"?>
<externaltool id="QtLLM.FixBuild">
  <description>Fix build issues: paste compiler/linker errors; select related code if possible</description>
  <displayname>qt-llm: Fix Build Error (Prompt)</displayname>
  <category>qt-llm</category>
  <order>4</order>
  <executable>qt-llm</executable>
  <arguments>--task fixbuild --extra %{Prompt:Paste build output / errors}</arguments>
  <input>CurrentSelection</input>
  <output>ShowInPane</output>
</externaltool>
<contexts>
  <context>Editor</context>
</contexts>